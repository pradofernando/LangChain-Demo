# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit the .env file to version control.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# LangChain Agent — Model Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Pick ONE of the two options below. If neither is set, the agent runs in
# mock mode (canned responses for demo purposes).

# Option 1 (RECOMMENDED): Foundry / Azure OpenAI deployment
# Get these from your Foundry project → Models → your deployment
AZURE_OPENAI_ENDPOINT=https://your-foundry.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Set to "true" to use Entra ID (Azure AD) auth via the Azure CLI instead of
# an API key. Required when the Foundry resource has key auth disabled.
# Prerequisite: run `az login` and have the "Cognitive Services OpenAI User"
# role on the resource. When true, AZURE_OPENAI_API_KEY can be left blank.
AZURE_OPENAI_USE_ENTRA_ID=false

# Option 2: Direct OpenAI (fallback only)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────────
# .NET Host Configuration
# ─────────────────────────────────────────────────────────────────────────────

# LangChain agent base URL
# Local: http://localhost:8000
# Foundry: https://your-foundry-endpoint.azurewebsites.net
LANGCHAIN_AGENT_BASE_URL=http://localhost:8000

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Foundry (for deployment)
# ─────────────────────────────────────────────────────────────────────────────

# Azure subscription and resource group
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group

# Foundry resource name
FOUNDRY_RESOURCE_NAME=your-foundry-resource

# Azure Container Registry (for container images)
AZURE_CONTAINER_REGISTRY=yourregistry.azurecr.io
IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Application Insights
# ─────────────────────────────────────────────────────────────────────────────

# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Authentication
# ─────────────────────────────────────────────────────────────────────────────

# Azure AD / Entra ID (for production)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
