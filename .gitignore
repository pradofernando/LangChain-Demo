# ============================================================================
# .gitignore - LangChain → Foundry Demo
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Secrets & Environment
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
*.secret
*.key
secrets/
user-secrets/

# ─────────────────────────────────────────────────────────────────────────────
# .NET
# ─────────────────────────────────────────────────────────────────────────────
bin/
obj/
*.dll
*.exe
*.pdb
*.user
*.suo
*.cache
.vs/
.vscode/launch.json
.vscode/tasks.json

# User secrets
appsettings.Development.json
appsettings.Local.json

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ─────────────────────────────────────────────────────────────────────────────
# IDEs
# ─────────────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────
# Azure & Deployment
# ─────────────────────────────────────────────────────────────────────────────
.azure/
azure.yaml
azd-deploy.json

# ─────────────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────────────────────────────────────
# Temporary files
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.bak
temp/
tmp/
